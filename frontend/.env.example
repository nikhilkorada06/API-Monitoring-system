# ─── API ────────────────────────────────────────────────────────────────────
# Base URL for all API calls.
# In development the Vite dev server proxies /api → http://localhost:5000,
# so the default value is correct.  Change only when pointing at a remote server.
VITE_API_BASE_URL=/api

# ─── Error Reporting ────────────────────────────────────────────────────────
# Optional: HTTPS endpoint that accepts a POST/sendBeacon with a JSON payload
# containing { message, stack, context, url, timestamp }.
# Leave empty to disable production error reporting.
VITE_ERROR_REPORT_URL=

# ─── Dev Server ─────────────────────────────────────────────────────────────
# Port the Vite dev server listens on (default: 5173).
PORT=5173
